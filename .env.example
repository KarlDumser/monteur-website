# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/monteur-website

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Admin Login
ADMIN_USER=admin
ADMIN_PASS=change_me

# Bot Live Console (Raspberry Pi via Tailscale SSH)
# Use either IP (100.84.86.61) or hostname (raspberrypi-1.tailccc131.ts.net)
BOT_SSH_HOST=100.84.86.61
BOT_SSH_USER=karldumser
BOT_SSH_PORT=22
# For local dev: Path to SSH private key file
BOT_SSH_KEY_PATH=~/.ssh/monteur_pi
# For Railway: Put the full private key content here (multiline string)
BOT_SSH_PRIVATE_KEY=
BOT_PROJECT_DIR=/home/karldumser/Projekt-Automatisierung-Kunden
BOT_SYSTEMD_SERVICE=wohnungsbot.service
