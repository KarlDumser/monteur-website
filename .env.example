# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/monteur-website

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Website Analytics
# Add your own visitor IDs here (comma-separated) to exclude your own devices from stats
ANALYTICS_EXCLUDED_VISITOR_IDS=
# Optional: exclude known IPs from stats (comma-separated)
ANALYTICS_EXCLUDED_IPS=
# Salt used for hashing analytics identifiers (change in production)
ANALYTICS_HASH_SALT=change-me-analytics-salt

# Admin Login
ADMIN_USER=admin
ADMIN_PASS=change_me
# Optional fuer mehrere Admins (du + Onkel), Format: user1:pass1;user2:pass2
# Wenn gesetzt, hat ADMIN_CREDENTIALS Vorrang vor ADMIN_USER/ADMIN_PASS
ADMIN_CREDENTIALS=

# Optional zusaetzliche Schutzschicht via Cloudflare Access (empfohlen fuer Produktion)
# true = /api/admin nur fuer Cloudflare Access Benutzer aus der E-Mail-Whitelist
ADMIN_REQUIRE_CLOUDFLARE_ACCESS=false
# Kommagetrennte Liste erlaubter Cloudflare Access E-Mails
ADMIN_ACCESS_ALLOWED_EMAILS=

# Bot Live Console (Raspberry Pi via Cloudflare Tunnel)
# Cloudflare Tunnel macht den Pi-Service öffentlich erreichbar (ohne Port Forwarding)
BOT_CONTROL_URL=https://unlimited-picnic-ministry-hub.trycloudflare.com
BOT_CONTROL_TOKEN=ghUz1ixu9H4UiWnBmvzY26rFRzzkenuu+q/gT4l2KmA=

